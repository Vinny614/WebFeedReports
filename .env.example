# Shared local development environment variables (copy to .env, never commit secrets)
# All Azure access uses Managed Identity / DefaultAzureCredential — no keys here.

# Managed identity (leave blank locally; resolves via developer Entra sign-in)
AZURE_CLIENT_ID=

# Storage
STORAGE_ACCOUNT_BLOB_URL=https://<account>.blob.core.windows.net
STORAGE_ACCOUNT_TABLE_URL=https://<account>.table.core.windows.net

# Azure AI Search
SEARCH_ENDPOINT=https://<search>.search.windows.net
SEARCH_INDEX_NAME=webfeed-chunks

# Azure OpenAI
OPENAI_ENDPOINT=https://<openai>.openai.azure.com
OPENAI_EMBED_DEPLOYMENT=text-embedding-3-large
OPENAI_CHAT_DEPLOYMENT=gpt-4o

# Service Bus
SERVICEBUS_FQDN=<namespace>.servicebus.windows.net
SERVICEBUS_INGEST_QUEUE=ingest-jobs
SERVICEBUS_REPORT_QUEUE=report-jobs

# Sources (Option B)
SOURCES_CONTAINER=sources
SOURCES_BLOB_NAME=sources.yaml

# Telemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Frontend
API_BASE_URL=http://localhost:8000
